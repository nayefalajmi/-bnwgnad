# Hesabe Payment Gateway — add these in Vercel Dashboard > Settings > Environment Variables
HESABE_SECRET_KEY=your_secret_key_here
HESABE_IV_KEY=your_iv_key_here

# Smart Accountant (المحاسب الذكي) — Anthropic Claude API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram order notifications (إشعارات تيليغرام للطلبات الجديدة)
TELEGRAM_BOT_TOKEN=123456:ABC-your_bot_token_from_BotFather
TELEGRAM_WEBHOOK_SECRET=any_long_random_string   # نفس القيمة تُوضع في ترويسة x-webhook-secret في Supabase Webhook
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Supabase ▸ Settings ▸ API ▸ service_role (سري)
